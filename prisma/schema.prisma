generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ADMIN USERS
// Roles: super_admin | admin | moderator | team_leader | staff
// ─────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String   @default("staff") // "super_admin" | "admin" | "moderator" | "team_leader" | "staff"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teamId String?
  team   Team?   @relation("TeamLeaders", fields: [teamId], references: [id])

  createdExams     Exam[]           @relation("ExamCreator")
  supervisedExams  Exam[]           @relation("ExamSupervisor")
  invitations      ExamInvitation[] @relation("InvitationCreator")
  questionBankItems QuestionBank[]  @relation("QuestionBankCreator")
  notifications    Notification[]
  auditLogs        AuditLog[]

  @@map("users")
}

// ─────────────────────────────────────────────
// OTP SESSIONS (admin login)
// ─────────────────────────────────────────────
model OtpSession {
  id        String   @id @default(cuid())
  email     String
  otpCode   String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("otp_sessions")
}

// ─────────────────────────────────────────────
// CANDIDATE OTP SESSIONS (candidate portal login)
// ─────────────────────────────────────────────
model CandidateOtpSession {
  id        String   @id @default(cuid())
  email     String
  otpCode   String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("candidate_otp_sessions")
}

// ─────────────────────────────────────────────
// TEAMS
// ─────────────────────────────────────────────
model Team {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#3B82F6")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members Audience[]
  leaders User[]     @relation("TeamLeaders")

  @@map("teams")
}

// ─────────────────────────────────────────────
// AUDIENCES (Medical Advisors / Candidates)
// ─────────────────────────────────────────────
model Audience {
  id                String   @id @default(cuid())
  name              String
  email             String   @unique
  preferredLanguage String   @default("EN")
  isActive          Boolean  @default(true)
  isArchived        Boolean  @default(false)
  nickname          String?
  realName          String?

  // Chain archived records for the same seat/nickname
  predecessorId String?
  predecessor   Audience?  @relation("SeatChain", fields: [predecessorId], references: [id])
  successors    Audience[] @relation("SeatChain")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id])

  examSessions ExamSession[]

  @@map("audiences")
}

// ─────────────────────────────────────────────
// EXAMS
// ─────────────────────────────────────────────
model Exam {
  id             String  @id @default(cuid())
  titleEn        String?
  titleFra       String?
  titleRu        String?
  titleTr        String?
  titleIta       String?
  descriptionEn  String?
  descriptionFra String?
  descriptionRu  String?
  descriptionTr  String?
  descriptionIta String?
  timePerQuestion Int     @default(60)

  // Lifecycle state: draft | scheduled | published | closed
  status             String    @default("draft")
  scheduledPublishAt DateTime? // auto-publish at this datetime
  isActive           Boolean   @default(true) // legacy compat; reflects published state

  // Validity & results
  validityHours          Int       @default(72)
  validityStartedAt      DateTime?
  resultsEmailSentAt     DateTime?
  resultAnnouncementDate DateTime? // supervisor deadline + manual release target

  // Configuration
  passMarkPercent Int @default(60)
  categories      String[] @default([])
  tags            String[] @default([])

  // Supervisor assignment
  supervisorId String?
  supervisor   User?   @relation("ExamSupervisor", fields: [supervisorId], references: [id], onDelete: SetNull)

  // Reminder tracking
  supervisorReminderSentAt DateTime? // when the 24h reminder was sent to supervisor
  candidateReminderSentAt  DateTime? // when the 24h pre-deadline reminder was sent

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy String?
  creator   User?   @relation("ExamCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  questions   Question[]
  sessions    ExamSession[]
  invitations ExamInvitation[]

  @@map("exams")
}

// ─────────────────────────────────────────────
// QUESTIONS
// ─────────────────────────────────────────────
model Question {
  id         String @id @default(cuid())
  examId     String
  orderIndex Int    @default(0)
  type       String @default("multiple_choice") // "multiple_choice" | "short_answer"

  questionEn  String?
  questionFra String?
  questionRu  String?
  questionTr  String?
  questionIta String?

  optionsEn  String?
  optionsFra String?
  optionsRu  String?
  optionsTr  String?
  optionsIta String?

  correctAnswer String? // null for short_answer

  // Short-answer scoring: scale 0–10
  maxScore Int @default(10)

  // Reference answer for AI scoring (all languages)
  referenceAnswerEn  String?
  referenceAnswerFra String?
  referenceAnswerRu  String?
  referenceAnswerTr  String?
  referenceAnswerIta String?

  explanationEn  String?
  explanationFra String?
  explanationRu  String?
  explanationTr  String?
  explanationIta String?

  // Link to question bank source (informational only, no cascade)
  questionBankId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  exam    Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  answers ExamAnswer[]

  @@map("questions")
}

// ─────────────────────────────────────────────
// QUESTION BANK (shared library, copy-on-import)
// ─────────────────────────────────────────────
model QuestionBank {
  id   String @id @default(cuid())
  type String @default("multiple_choice")

  questionEn  String?
  questionFra String?
  questionRu  String?
  questionTr  String?
  questionIta String?

  optionsEn  String?
  optionsFra String?
  optionsRu  String?
  optionsTr  String?
  optionsIta String?

  correctAnswer String?
  maxScore      Int     @default(10)

  referenceAnswerEn  String?
  referenceAnswerFra String?
  referenceAnswerRu  String?
  referenceAnswerTr  String?
  referenceAnswerIta String?

  explanationEn  String?
  explanationFra String?
  explanationRu  String?
  explanationTr  String?
  explanationIta String?

  categories  String[] @default([])
  tags        String[] @default([])
  usedInCount Int      @default(0)

  createdBy String?
  creator   User?   @relation("QuestionBankCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("question_bank")
}

// ─────────────────────────────────────────────
// EXAM INVITATIONS
// ─────────────────────────────────────────────
model ExamInvitation {
  id          String   @id @default(cuid())
  examId      String
  email       String
  name        String?
  uniqueToken String   @unique @default(cuid())
  otpCode     String?
  expiresAt   DateTime
  isUsed      Boolean  @default(false)
  createdBy   String?
  createdAt   DateTime @default(now())

  exam     Exam        @relation(fields: [examId], references: [id])
  creator  User?       @relation("InvitationCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  sessions ExamSession[]

  @@map("exam_invitations")
}

// ─────────────────────────────────────────────
// EXAM SESSIONS
// ─────────────────────────────────────────────
model ExamSession {
  id            String  @id @default(cuid())
  examId        String
  audienceId    String?
  invitationId  String?
  externalEmail String?
  externalName  String?

  selectedLanguage String
  questionOrder    String
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  score            Int?
  totalQuestions   Int?
  correctCount     Int?
  wrongCount       Int?
  skippedCount     Int?
  timeTaken        Int?
  // in_progress | pending_review | completed
  status           String    @default("in_progress")

  completionEmailSent Boolean @default(false)
  resultEmailSent     Boolean @default(false)

  // Preview session — not saved to results, used only for admin exam preview
  isPreview Boolean @default(false)

  exam       Exam            @relation(fields: [examId], references: [id])
  audience   Audience?       @relation(fields: [audienceId], references: [id])
  invitation ExamInvitation? @relation(fields: [invitationId], references: [id])
  answers    ExamAnswer[]

  @@map("exam_sessions")
}

// ─────────────────────────────────────────────
// EXAM ANSWERS
// ─────────────────────────────────────────────
model ExamAnswer {
  id             String   @id @default(cuid())
  sessionId      String
  questionId     String
  selectedAnswer String?
  isCorrect      Boolean?
  answeredAt     DateTime @default(now())

  // Manual scoring for short_answer (0–10)
  manualScore    Int?
  manualFeedback String?
  reviewedAt     DateTime?
  reviewedBy     String?

  // AI suggested score
  aiSuggestedScore   Float?
  aiSuggestionStatus String? // "pending" | "accepted" | "revised"

  session  ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id])

  @@unique([sessionId, questionId])
  @@map("exam_answers")
}

// ─────────────────────────────────────────────
// EMAIL LOGS
// ─────────────────────────────────────────────
model EmailLog {
  id         String   @id @default(cuid())
  to         String
  subject    String
  type       String   // otp | invitation | result | completion | reminder | supervisor_reminder | assignment
  status     String   @default("sent") // sent | failed
  error      String?
  retryCount Int      @default(0)
  sentAt     DateTime @default(now())

  audienceId String?
  examId     String?
  sessionId  String?

  @@map("email_logs")
}

// ─────────────────────────────────────────────
// AUDIT LOGS
// ─────────────────────────────────────────────
model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  userEmail String
  userRole  String
  action    String   // create | update | delete | publish | assign | release | duplicate
  entity    String   // exam | question | audience | user | team | question_bank
  entityId  String?
  changes   String?  // JSON description of what changed
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// IN-APP NOTIFICATIONS
// ─────────────────────────────────────────────
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // review_needed | deadline_reminder | results_released | exam_assigned
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
